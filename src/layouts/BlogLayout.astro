---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.vue';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const { title, description, ogImage, ogType, canonical } = Astro.props;
---

<Layout title={title} description={description} ogImage={ogImage} ogType={ogType} canonical={canonical}>
  <Navigation client:load />
  
  <main class="container mx-auto pt-[clamp(5rem,15vh,8rem)] min-h-screen">
    <div class="relative">
      <slot />
    </div>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --header-height: 4rem;
    --footer-height: 2rem;
  }

  main {
    min-height: calc(100vh - var(--header-height) - var(--footer-height));
  }
</style>